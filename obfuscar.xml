<?xml version="1.0" encoding="utf-8" ?>
<Obfuscator>
  <Var name="InPath" value="." />
  <Var name="OutPath" value=".\Obfuscator" />

  <Var name="LogFile" value=".obfuscator.log" />
  <Var name="RenameProperties" value="true" />
  <Var name="RenameEvents" value="true" />
  <Var name="RenameFields" value="true" />
  <Var name="KeepPublicApi" value="true" />
  <Var name="UseUnicodeNames" value="true" />
  <Var name="HidePrivateApi" value="true" />
  <Var name="HideStrings" value="true" />
  <Var name="OptimizeMethods" value="true" />
  <Var name="SuppressIldasm" value="tue" />

  <Module file="$(InPath)\BusinessGlobal.dll" />
  <Module file="$(InPath)\Entity.dll" />
  <Module file="$(InPath)\Repositorio.dll" />
  <Module file="$(InPath)\WebVentas.dll" />
</Obfuscator>